# =============================================================================
# 环境变量配置
# =============================================================================
# 请根据实际情况填写以下配置
# 注意：此文件包含敏感信息，不要提交到版本控制系统
# =============================================================================

# =============================================================================
# OKX API 配置
# =============================================================================
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=
OKX_SANDBOX=false

# =============================================================================
# 通知系统配置
# =============================================================================
NOTIFICATION_ENABLED=true
NOTIFICATION_MIN_LEVEL=INFO

# =============================================================================
# Webhook 通知配置
# =============================================================================
WEBHOOK_URL=
WEBHOOK_METHOD=POST
WEBHOOK_FORMAT=JSON

# =============================================================================
# 邮件通知配置
# =============================================================================
BTC_NOTICE_SMTP_PASSWD_1=
BTC_NOTICE_SMTP_PASSWD_2=
BTC_NOTICE_SMTP_PASSWD_3=
